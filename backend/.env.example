# Rakiz backend environment template.
# Copy to .env and fill in real values. Never commit the real .env.

# --- Server ---
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# --- MySQL (local in dev) ---
# In dev outside Docker use 127.0.0.1. When running via docker-compose the
# compose file overrides MYSQL_HOST to host.docker.internal automatically.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=rakiz

# --- MongoDB Atlas ---
MONGO_URI=

# --- Redis Cloud ---
REDIS_URL=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# --- Email (Resend) ---
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev

# --- Auth tokens ---
# Use long random strings, different for each. e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
EMAIL_VERIFY_SECRET=
EMAIL_VERIFY_TTL=24h

# Backend base URL, used to build the email verification link.
API_URL=http://localhost:5000

# AI (OpenAI) and AES encryption keys are added in their respective phases;
# documented here as they come online.
